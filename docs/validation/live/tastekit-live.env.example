# Copy this file to docs/validation/live/tastekit-live.env before filling values.
# That local file is gitignored and auto-loaded by the live harness.
# Run with: pnpm test:live-e2e:preflight

OPENAI_API_KEY=
ZAI_API_KEY=

# Defaults are shown here so the live run is reproducible.
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-5.5
ZAI_BASE_URL=https://api.z.ai/api/coding/paas/v4
ZAI_MODEL=glm-5.1
ZAI_THINKING=disabled

# General Z.ai API keys can use:
# ZAI_BASE_URL=https://api.z.ai/api/paas/v4
