{
  "name": "tastekit",
  "version": "0.2.0",
  "description": "Pre-1.0 taste onboarding, skills, MCP, drift, trust, and runtime artifact tooling for AI agents",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.29.2",
  "repository": {
    "type": "git",
    "url": "https://github.com/philipbankier/tastekit.git"
  },
  "homepage": "https://github.com/philipbankier/tastekit",
  "bugs": {
    "url": "https://github.com/philipbankier/tastekit/issues"
  },
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r build && pnpm -r test && pnpm test:live-e2e:unit",
    "demo:one-pager": "pnpm --filter @actrun_ai/tastekit-core build && node scripts/demo/render-one-pager.mjs",
    "test:pr-gate": "bash scripts/validation/pr-gate.sh",
    "test:pre-release-live": "bash scripts/validation/pre-release-live-ollama.sh",
    "test:live-e2e:unit": "node --test scripts/validation/__tests__/*.test.mjs",
    "test:live-e2e:preflight": "pnpm -r build && node scripts/validation/live-full-composition-e2e.mjs --preflight-only",
    "test:live-e2e:diagnostics": "pnpm -r build && node scripts/validation/live-provider-diagnostics.mjs",
    "test:live-e2e:mock": "pnpm -r build && node scripts/validation/mock-live-full-composition-e2e.mjs",
    "test:live-e2e": "pnpm -r build && node scripts/validation/live-full-composition-e2e.mjs",
    "test:live-e2e:assert-latest": "node scripts/validation/assert-live-e2e-release-evidence.mjs",
    "test:live-e2e:release": "pnpm -r build && node scripts/validation/run-live-e2e-release-sequence.mjs",
    "test:live-e2e:subscription-demo": "pnpm -r build && node scripts/validation/run-live-e2e-subscription-demo-sequence.mjs",
    "configure:live-e2e": "node scripts/validation/configure-live-env.mjs",
    "lint": "pnpm -r lint",
    "clean": "pnpm -r clean"
  },
  "keywords": [
    "taste",
    "agent",
    "mcp",
    "skills",
    "cli",
    "trust",
    "tracing"
  ],
  "author": "TasteKit Contributors",
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.3.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.56.1",
    "vitest": "^2.0.0"
  },
  "dependencies": {
    "@actrun_ai/tastekit-adapters": "workspace:*",
    "@actrun_ai/tastekit-core": "workspace:*"
  }
}
