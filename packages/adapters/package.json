{
  "name": "@kairox_ai/tastekit-adapters",
  "version": "0.2.0",
  "description": "Pre-1.0 TasteKit runtime adapters for Claude Code, OpenClaw, Manus, Autopilots, AGENTS.md, and Agent File",
  "type": "module",
  "license": "MIT",
  "author": "TasteKit Contributors",
  "repository": {
    "type": "git",
    "url": "https://github.com/philipbankier/tastekit.git",
    "directory": "packages/adapters"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./adapter-interface": "./dist/adapter-interface.js",
    "./claude-code": "./dist/claude-code/index.js",
    "./manus": "./dist/manus/index.js",
    "./openclaw": "./dist/openclaw/index.js",
    "./autopilots": "./dist/autopilots/index.js"
  },
  "scripts": {
    "build": "tsc",
    "test": "pnpm --filter @kairox_ai/tastekit-core build && vitest run",
    "lint": "eslint --ignore-pattern dist/ --ignore-pattern __tests__/ .",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@kairox_ai/tastekit-core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0",
    "vitest": "^2.0.0"
  },
  "keywords": [
    "ai-agent",
    "agent",
    "skills",
    "agent-skills",
    "agents-md",
    "mcp",
    "taste",
    "onboarding",
    "llm",
    "open-source"
  ]
}
