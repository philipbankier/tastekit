{
  "name": "@actrun_ai/tastekit-validator",
  "version": "0.2.0",
  "description": "Pre-1.0 validator for TasteKit constitution artifacts",
  "type": "module",
  "license": "MIT",
  "author": "TasteKit Contributors",
  "repository": {
    "type": "git",
    "url": "https://github.com/philipbankier/tastekit.git",
    "directory": "packages/validator"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "bin": {
    "tastekit-validator": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "test": "pnpm --filter @actrun_ai/tastekit-core build && vitest run",
    "lint": "eslint --ignore-pattern dist/ --ignore-pattern __tests__/ src/",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@actrun_ai/tastekit-core": "workspace:*",
    "ajv": "^8.12.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0",
    "vitest": "^2.0.0"
  },
  "keywords": [
    "ai-agent",
    "agent",
    "skills",
    "agent-skills",
    "agents-md",
    "mcp",
    "taste",
    "onboarding",
    "llm",
    "open-source"
  ]
}
