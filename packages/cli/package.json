{
  "name": "@actrun_ai/tastekit-cli",
  "version": "0.2.0",
  "description": "Pre-1.0 CLI for compiling human taste into portable AI agent artifacts",
  "type": "module",
  "license": "MIT",
  "author": "TasteKit Contributors",
  "repository": {
    "type": "git",
    "url": "https://github.com/philipbankier/tastekit.git",
    "directory": "packages/cli"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "bin": {
    "tastekit": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "test": "pnpm --filter @actrun_ai/tastekit-core build && pnpm --filter @actrun_ai/tastekit-adapters build && pnpm run build && vitest run",
    "test:integration": "pnpm --filter @actrun_ai/tastekit-core build && pnpm --filter @actrun_ai/tastekit-adapters build && pnpm run build && vitest run tests/integration",
    "lint": "eslint src/",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@actrun_ai/tastekit-adapters": "workspace:*",
    "@actrun_ai/tastekit-core": "workspace:*",
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "inquirer": "^10.0.0",
    "ora": "^8.0.0",
    "uuid": "^13.0.0",
    "yaml": "^2.8.2"
  },
  "optionalDependencies": {
    "@actrun_ai/tastekit-voice": "workspace:*"
  },
  "devDependencies": {
    "@types/inquirer": "^9.0.0",
    "@types/node": "^22.0.0",
    "@types/uuid": "^11.0.0",
    "typescript": "^5.6.0",
    "vitest": "^2.0.0"
  },
  "keywords": [
    "ai-agent",
    "agent",
    "skills",
    "agent-skills",
    "agents-md",
    "mcp",
    "taste",
    "onboarding",
    "llm",
    "open-source"
  ]
}
