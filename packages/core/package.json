{
  "name": "@tastekit/core",
  "version": "1.0.0",
  "description": "TasteKit core library - schemas, compiler, skills, MCP, trust, tracing",
  "type": "module",
  "license": "MIT",
  "author": "TasteKit Contributors",
  "repository": {
    "type": "git",
    "url": "https://github.com/tastekit/tastekit.git",
    "directory": "packages/core"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./schemas": "./dist/schemas/index.js",
    "./compiler": "./dist/compiler/index.js",
    "./interview": "./dist/interview/index.js",
    "./domains": "./dist/domains/index.js",
    "./llm": "./dist/llm/index.js",
    "./generators": "./dist/generators/index.js",
    "./skills": "./dist/skills/index.js",
    "./mcp": "./dist/mcp/index.js",
    "./trust": "./dist/trust/index.js",
    "./tracing": "./dist/tracing/index.js",
    "./drift": "./dist/drift/index.js",
    "./eval": "./dist/eval/index.js",
    "./utils": "./dist/utils/index.js"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint --ignore-pattern dist/ --ignore-pattern __tests__/ .",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "yaml": "^2.4.0",
    "zod": "^3.23.0",
    "ajv": "^8.12.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0",
    "vitest": "^2.0.0"
  }
}
